page {
  min-height: 100%;
  background: #f5f9ff;
  color: #111827;
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "PingFang SC", "Helvetica Neue", sans-serif;
  font-weight: 400;
}

view,
text,
button,
input {
  box-sizing: border-box;
}

button {
  display: block;
  padding: 0;
  margin: 0;
  line-height: 1;
  background: transparent;
  border: 0;
  border-radius: 0;
  font: inherit;
  color: inherit;
}

button::after {
  border: 0;
}

.page-shell {
  min-height: 100vh;
  padding: 30rpx 30rpx 198rpx;
}

.glass-card {
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(182, 205, 232, 0.46);
  border-radius: 28rpx;
  box-shadow: 0 18rpx 42rpx rgba(45, 92, 148, 0.12), inset 0 0 0 1rpx rgba(255, 255, 255, 0.62);
}

.muted {
  color: #7b8492;
}

.primary {
  color: #2f86f6;
}

.bottom-nav {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  height: calc(124rpx + env(safe-area-inset-bottom));
  padding: 8rpx 22rpx env(safe-area-inset-bottom);
  display: flex;
  align-items: stretch;
  background: rgba(255, 255, 255, 0.97);
  border-top: 1rpx solid rgba(182, 205, 232, 0.55);
  box-shadow: 0 -14rpx 38rpx rgba(35, 76, 126, 0.08);
}

.bottom-nav-item {
  flex: 1;
  min-width: 0;
  height: 102rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #9098a6;
  font-size: 22rpx;
  font-weight: 400;
  line-height: 1;
  text-align: center;
  white-space: nowrap;
  word-break: keep-all;
  overflow: hidden;
}

.nav-slot-1 {
}

.nav-slot-2 {
}

.nav-slot-3 {
}

.bottom-nav-item.active {
  color: #2f86f6;
}

.bottom-nav-icon {
  display: block;
  width: 42rpx;
  height: 42rpx;
  margin-bottom: 7rpx;
}

.bottom-nav-item.active .bottom-nav-icon {
  transform: translateY(-1rpx);
}

.bottom-nav-label {
  display: block;
  width: 100%;
  color: inherit;
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1.1;
  text-align: center;
  white-space: nowrap;
  word-break: keep-all;
}
