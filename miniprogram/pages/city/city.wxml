<view class="page-shell">
  <view class="city-header">
    <text class="eyebrow">城市</text>
    <text class="title">选择洗车城市</text>
    <text class="subtitle">选好常用位置后，首页会按当地天气给出洗车建议。</text>
  </view>

  <view class="search-card glass-card">
    <view class="search-field {{searchFocused ? 'focused' : ''}}">
      <text class="search-mark">搜</text>
      <input
        class="search-input"
        value="{{searchKeyword}}"
        placeholder="搜索城市、区县"
        placeholder-class="search-placeholder"
        confirm-type="search"
        bindinput="handleSearchInput"
        bindconfirm="handleSearchConfirm"
        bindfocus="handleSearchFocus"
        bindblur="handleSearchBlur"
      />
      <button
        wx:if="{{hasSearchKeyword}}"
        class="search-clear"
        hover-class="none"
        bindtap="clearSearch"
      >×</button>
    </view>

    <view wx:if="{{searchLoading}}" class="search-state">
      <view class="search-spinner"></view>
      <text>正在搜索城市</text>
    </view>

    <view wx:elif="{{searchError}}" class="search-state search-state-error">
      <text class="search-state-text">{{searchError}}</text>
      <button class="search-retry" hover-class="none" bindtap="retrySearch">重试</button>
    </view>

    <view wx:elif="{{searchTouched && hasSearchKeyword && searchResults.length === 0}}" class="search-state">
      <text>没有找到匹配城市</text>
    </view>

    <view wx:elif="{{searchResults.length > 0}}" class="search-results">
      <button
        wx:for="{{searchResults}}"
        wx:key="id"
        class="search-result-row"
        hover-class="search-result-hover"
        data-index="{{index}}"
        bindtap="handleSearchResultTap"
      >
        <view class="search-result-copy">
          <text class="search-result-name">{{item.displayName}}</text>
          <text class="search-result-meta">{{item.metaText}}</text>
        </view>
        <text class="search-result-action">选择</text>
      </button>
    </view>
  </view>

  <view class="region-picker glass-card" bindtap="toggleSelector">
    <view>
      <text class="picker-label">当前选择</text>
      <text class="picker-value">{{currentCityText}}</text>
    </view>
    <text class="picker-action">{{selectorOpen ? "收起" : "更换"}}</text>
  </view>

  <view wx:if="{{selectorOpen}}" class="selector-panel glass-card">
    <view class="selector-head">
      <text>请选择地区</text>
      <text class="selector-current">{{selectedRegionText}}</text>
    </view>
    <view class="selector-columns">
      <scroll-view class="selector-column" scroll-y scroll-into-view="{{provinceAnchor}}">
        <view
          wx:for="{{provinceList}}"
          wx:key="code"
          id="province-{{item.code}}"
          class="selector-option {{index === regionValue[0] ? 'active' : ''}}"
          data-index="{{index}}"
          bindtap="handleProvinceTap"
        >{{item.name}}</view>
      </scroll-view>
      <scroll-view class="selector-column" scroll-y scroll-into-view="{{cityAnchor}}">
        <view
          wx:for="{{cityList}}"
          wx:key="code"
          id="city-{{item.code}}"
          class="selector-option {{index === regionValue[1] ? 'active' : ''}}"
          data-index="{{index}}"
          bindtap="handleCityTap"
        >{{item.name}}</view>
      </scroll-view>
      <scroll-view class="selector-column" scroll-y scroll-into-view="{{countyAnchor}}">
        <view
          wx:for="{{countyList}}"
          wx:key="code"
          id="county-{{item.code}}"
          class="selector-option {{index === regionValue[2] ? 'active' : ''}}"
          data-index="{{index}}"
          bindtap="handleCountyTap"
        >{{item.name}}</view>
      </scroll-view>
    </view>
  </view>

  <view class="hint-card">
    <text class="hint-title">选择到区县更准确</text>
    <text class="hint-desc">天气可能因城区不同略有差异，建议选择你平时洗车或停车的位置。</text>
  </view>

  <button class="back-home-button" bindtap="goIndex">返回洗车指数</button>
</view>
