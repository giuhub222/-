.city-header {
  margin-bottom: 28rpx;
  padding: 2rpx 2rpx 0;
}

.eyebrow {
  display: block;
  color: #007aff;
  font-size: 23rpx;
  font-weight: 500;
  margin-bottom: 10rpx;
}

.title {
  display: block;
  color: #111827;
  font-size: 42rpx;
  line-height: 1.08;
  font-weight: 600;
  letter-spacing: 0;
}

.subtitle {
  display: block;
  margin-top: 12rpx;
  color: #7d8795;
  font-size: 25rpx;
  line-height: 1.5;
}

.search-card {
  margin-bottom: 18rpx;
  padding: 18rpx;
}

.search-field {
  height: 78rpx;
  padding: 0 12rpx 0 22rpx;
  border: 2rpx solid rgba(182, 205, 232, 0.42);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  background: #f7faff;
  transition: border-color 0.16s ease, background 0.16s ease, box-shadow 0.16s ease;
}

.search-field.focused {
  border-color: rgba(47, 134, 246, 0.78);
  background: #ffffff;
  box-shadow: 0 12rpx 26rpx rgba(47, 134, 246, 0.12);
}

.search-mark {
  flex: 0 0 46rpx;
  width: 46rpx;
  height: 46rpx;
  border-radius: 23rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(47, 134, 246, 0.1);
  color: #2f86f6;
  font-size: 22rpx;
  font-weight: 650;
  line-height: 1;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  margin-left: 16rpx;
  color: #111827;
  font-size: 27rpx;
  font-weight: 500;
  line-height: 76rpx;
}

.search-placeholder {
  color: #9aa5b4;
  font-weight: 400;
}

.search-clear {
  flex: 0 0 52rpx;
  width: 52rpx;
  height: 52rpx;
  margin-left: 10rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #edf2f8;
  color: #7d8795;
  font-size: 34rpx;
  font-weight: 400;
  line-height: 1;
}

.search-state {
  min-height: 78rpx;
  margin-top: 14rpx;
  padding: 18rpx 18rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: #f7faff;
  color: #7d8795;
  font-size: 24rpx;
  font-weight: 500;
  text-align: center;
}

.search-state-error {
  justify-content: space-between;
  background: #fff6f6;
  color: #c2413d;
  text-align: left;
}

.search-state-text {
  flex: 1;
  min-width: 0;
  line-height: 1.35;
}

.search-spinner {
  width: 28rpx;
  height: 28rpx;
  border: 4rpx solid rgba(47, 134, 246, 0.18);
  border-top-color: #2f86f6;
  border-radius: 50%;
  animation: city-search-spin 0.8s linear infinite;
}

.search-retry {
  flex: 0 0 92rpx;
  width: 92rpx;
  height: 50rpx;
  margin-left: 14rpx;
  border-radius: 25rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  color: #c2413d;
  font-size: 23rpx;
  font-weight: 650;
}

.search-results {
  margin-top: 14rpx;
  overflow: hidden;
  border-radius: 22rpx;
  background: #f7faff;
}

.search-result-row {
  min-height: 92rpx;
  padding: 18rpx 18rpx 18rpx 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  background: #f7faff;
  border-bottom: 1rpx solid rgba(182, 205, 232, 0.46);
  color: #111827;
  text-align: left;
}

.search-result-row:last-child {
  border-bottom: 0;
}

.search-result-hover {
  background: #eef6ff;
}

.search-result-copy {
  flex: 1;
  min-width: 0;
}

.search-result-name {
  display: block;
  overflow: hidden;
  color: #111827;
  font-size: 28rpx;
  font-weight: 650;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.search-result-meta {
  display: block;
  margin-top: 6rpx;
  overflow: hidden;
  color: #7d8795;
  font-size: 22rpx;
  font-weight: 400;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.search-result-action {
  flex: 0 0 auto;
  min-width: 76rpx;
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  color: #2f86f6;
  font-size: 22rpx;
  font-weight: 650;
  box-shadow: 0 8rpx 18rpx rgba(47, 134, 246, 0.1);
}

.region-picker {
  min-height: 138rpx;
  padding: 26rpx 26rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #111827;
}

.picker-label {
  display: block;
  margin-bottom: 10rpx;
  color: #8a93a1;
  font-size: 22rpx;
  font-weight: 400;
}

.picker-value {
  display: block;
  max-width: 470rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #111827;
  font-size: 32rpx;
  font-weight: 600;
}

.picker-action {
  flex: 0 0 auto;
  min-width: 112rpx;
  height: 56rpx;
  margin-left: 20rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #007aff;
  color: #fff;
  font-size: 23rpx;
  font-weight: 600;
  box-shadow: 0 14rpx 30rpx rgba(0, 122, 255, 0.18);
}

.selector-panel {
  margin-top: 18rpx;
  padding: 22rpx;
}

.selector-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
  color: #111827;
  font-size: 24rpx;
  font-weight: 500;
}

.selector-current {
  flex: 1;
  overflow: hidden;
  color: #7d8795;
  font-size: 22rpx;
  font-weight: 650;
  text-align: right;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.selector-columns {
  height: 430rpx;
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 12rpx;
}

.selector-column {
  height: 430rpx;
  padding: 8rpx;
  border-radius: 24rpx;
  background: rgba(245, 248, 252, 0.9);
}

.selector-option {
  min-height: 62rpx;
  margin-bottom: 8rpx;
  padding: 14rpx 12rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #596474;
  font-size: 22rpx;
  font-weight: 400;
  line-height: 1.2;
  text-align: center;
  word-break: keep-all;
}

.selector-option.active {
  color: #007aff;
  background: #fff;
  box-shadow: 0 10rpx 24rpx rgba(25, 38, 58, 0.08);
}

.hint-card {
  margin-top: 24rpx;
  padding: 0 4rpx;
}

.hint-title {
  display: block;
  color: #2f3a4a;
  font-size: 25rpx;
  font-weight: 500;
}

.hint-desc {
  display: block;
  margin-top: 8rpx;
  color: #7d8795;
  font-size: 23rpx;
  line-height: 1.5;
  white-space: normal;
}

.picker-label,
.picker-value,
.picker-action,
.hint-title {
  white-space: nowrap;
}

.back-home-button {
  height: 82rpx;
  margin-top: 34rpx;
  border-radius: 41rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #2f86f6;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 600;
  box-shadow: 0 16rpx 32rpx rgba(47, 134, 246, 0.24);
}

@keyframes city-search-spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}
