.city-header {
  margin-bottom: 28rpx;
  padding: 2rpx 2rpx 0;
}

.eyebrow {
  display: block;
  color: #007aff;
  font-size: 23rpx;
  font-weight: 500;
  margin-bottom: 10rpx;
}

.title {
  display: block;
  color: #111827;
  font-size: 42rpx;
  line-height: 1.08;
  font-weight: 600;
  letter-spacing: 0;
}

.subtitle {
  display: block;
  margin-top: 12rpx;
  color: #7d8795;
  font-size: 25rpx;
  line-height: 1.5;
}

.region-picker {
  min-height: 138rpx;
  padding: 26rpx 26rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #111827;
}

.picker-label {
  display: block;
  margin-bottom: 10rpx;
  color: #8a93a1;
  font-size: 22rpx;
  font-weight: 400;
}

.picker-value {
  display: block;
  max-width: 470rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #111827;
  font-size: 32rpx;
  font-weight: 600;
}

.picker-action {
  flex: 0 0 auto;
  min-width: 112rpx;
  height: 56rpx;
  margin-left: 20rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #007aff;
  color: #fff;
  font-size: 23rpx;
  font-weight: 600;
  box-shadow: 0 14rpx 30rpx rgba(0, 122, 255, 0.18);
}

.selector-panel {
  margin-top: 18rpx;
  padding: 22rpx;
}

.selector-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
  color: #111827;
  font-size: 24rpx;
  font-weight: 500;
}

.selector-current {
  flex: 1;
  overflow: hidden;
  color: #7d8795;
  font-size: 22rpx;
  font-weight: 650;
  text-align: right;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.selector-columns {
  height: 430rpx;
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 12rpx;
}

.selector-column {
  height: 430rpx;
  padding: 8rpx;
  border-radius: 24rpx;
  background: rgba(245, 248, 252, 0.9);
}

.selector-option {
  min-height: 62rpx;
  margin-bottom: 8rpx;
  padding: 14rpx 12rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #596474;
  font-size: 22rpx;
  font-weight: 400;
  line-height: 1.2;
  text-align: center;
  word-break: keep-all;
}

.selector-option.active {
  color: #007aff;
  background: #fff;
  box-shadow: 0 10rpx 24rpx rgba(25, 38, 58, 0.08);
}

.hint-card {
  margin-top: 24rpx;
  padding: 0 4rpx;
}

.hint-title {
  display: block;
  color: #2f3a4a;
  font-size: 25rpx;
  font-weight: 500;
}

.hint-desc {
  display: block;
  margin-top: 8rpx;
  color: #7d8795;
  font-size: 23rpx;
  line-height: 1.5;
  white-space: normal;
}

.picker-label,
.picker-value,
.picker-action,
.hint-title {
  white-space: nowrap;
}

.back-home-button {
  height: 82rpx;
  margin-top: 34rpx;
  border-radius: 41rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #2f86f6;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 600;
  box-shadow: 0 16rpx 32rpx rgba(47, 134, 246, 0.24);
}
