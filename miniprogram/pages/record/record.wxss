.record-page {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
  background: linear-gradient(180deg, #f8fbff 0%, #f3f7fc 100%);
}

.record-topbar {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  z-index: 40;
  width: 100%;
  background: #ffffff;
}

.record-status-space {
  width: 100%;
}

.record-topbar-row {
  width: 100%;
  display: grid;
  align-items: center;
}

.record-nav-balance-slot,
.record-nav-capsule-slot,
.record-nav-title-slot {
  min-width: 0;
  height: 100%;
}

.record-nav-title-slot {
  display: flex;
  align-items: center;
  justify-content: center;
}

.record-topbar-title {
  color: #151b26;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.2;
  text-align: center;
  white-space: nowrap;
}

.record-topbar-divider {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 1rpx;
  background: #edf1f6;
}

.record-scroll {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1;
  width: 100%;
  background: linear-gradient(180deg, #f8fbff 0%, #f3f7fc 100%);
}

.record-content {
  padding: 16rpx 32rpx calc(180rpx + env(safe-area-inset-bottom));
}

.record-tabs {
  width: 100%;
  height: 92rpx;
  padding: 6rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
  overflow: hidden;
  background: #ffffff;
  border-radius: 28rpx;
  border: 1rpx solid rgba(220, 230, 245, 0.8);
  box-shadow: 0 4rpx 16rpx rgba(30, 80, 150, 0.06);
}

.record-tab {
  flex: 1;
  min-width: 0;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border-radius: 22rpx;
  color: #2f3a4a;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1;
  text-align: center;
  white-space: nowrap;
  transition: none;
}

.record-tab.active {
  background-color: #2f86f6;
  color: #ffffff;
  font-weight: 700;
  opacity: 1;
}

.record-tab-label {
  line-height: 1;
}

.overview-selector-hover,
.month-head-hover,
.button-hover {
  opacity: 0.78;
}

.overview-card {
  margin-top: 24rpx;
}

.overview-card-all,
.overview-card-all .overview-hero,
.overview-card-all .overview-panel {
  width: 100%;
  box-sizing: border-box;
}

.overview-card-all .overview-panel {
  margin-left: 0;
  margin-right: 0;
}

.overview-hero {
  position: relative;
  height: 156rpx;
  padding: 20rpx 28rpx 46rpx;
  overflow: hidden;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #3f91fa 0%, #67a9fa 100%);
  box-shadow: 0 8rpx 20rpx rgba(47, 134, 246, 0.12);
}

.overview-month-picker {
  position: relative;
  z-index: 3;
  display: block;
  width: 58%;
}

.overview-selector {
  width: 100%;
  min-height: 64rpx;
  display: flex;
  align-items: flex-start;
  justify-content: flex-start;
  text-align: left;
}

.overview-selector-copy {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  text-align: left;
}

.overview-month-row {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 8rpx;
}

.overview-month {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 680;
  line-height: 1.2;
}

.overview-chevron {
  color: rgba(255, 255, 255, 0.9);
  font-size: 15rpx;
  line-height: 1;
}

.overview-subtitle {
  display: block;
  width: 100%;
  margin-top: 6rpx;
  color: rgba(255, 255, 255, 0.86);
  font-size: 23rpx;
  font-weight: 450;
  line-height: 1.2;
  text-align: left;
}

.overview-image {
  position: absolute;
  right: 8rpx;
  bottom: 4rpx;
  z-index: 1;
  width: 196rpx;
  height: 134rpx;
}

.overview-spark {
  position: absolute;
  z-index: 2;
  width: 7rpx;
  height: 7rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.72);
}

.spark-a {
  right: 182rpx;
  top: 42rpx;
}

.spark-b {
  right: 198rpx;
  top: 66rpx;
}

.spark-c {
  right: 168rpx;
  top: 84rpx;
}

.overview-panel {
  position: relative;
  z-index: 4;
  margin: -28rpx 12rpx 0;
  border-radius: 40rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  overflow: hidden;
  background: #ffffff;
  border: 1rpx solid #e7edf5;
  box-shadow: 0 6rpx 16rpx rgba(49, 83, 126, 0.055);
}

.overview-metric {
  min-width: 0;
  min-height: 110rpx;
  padding: 10rpx 20rpx 8rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
}

.metric-0,
.metric-2 {
  border-right: 1rpx solid rgba(225, 233, 243, 0.72);
}

.metric-0,
.metric-1 {
  border-bottom: 1rpx solid rgba(225, 233, 243, 0.72);
}

.metric-label {
  color: #697586;
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1.1;
}

.metric-value {
  display: block;
  width: 100%;
  margin-top: 5rpx;
  color: #182231;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.1;
  white-space: nowrap;
}

.metric-foot-value {
  display: block;
  width: 100%;
  margin-top: 4rpx;
  color: #98a2b1;
  font-size: 24rpx;
  font-weight: 450;
  line-height: 1.05;
  white-space: nowrap;
}

.metric-foot-value.up {
  color: #e65d4f;
}

.metric-foot-value.neutral {
  color: #98a2b1;
}

.metric-foot-value.down {
  color: #2f9b63;
}

.metric-0 .metric-label,
.metric-1 .metric-label {
  color: #566477;
  font-weight: 600;
}

.metric-2 .metric-value,
.metric-3 .metric-value {
  font-size: 28rpx;
  font-weight: 650;
}

.stats-overview-card {
  margin-top: 24rpx;
}

.stats-summary-head {
  padding: 0 4rpx;
}

.stats-overview-panel {
  margin: 14rpx 0 0;
}

.state-card,
.month-group,
.trend-card {
  margin-top: 24rpx;
  border-radius: 44rpx;
  background: #ffffff;
  border: 1rpx solid #e7edf5;
  box-shadow: 0 4rpx 12rpx rgba(49, 83, 126, 0.04);
}

.state-card {
  padding: 34rpx 28rpx;
  text-align: center;
}

.state-title {
  display: block;
  color: #182231;
  font-size: 27rpx;
  font-weight: 650;
  line-height: 1.3;
}

.state-description {
  display: block;
  margin-top: 10rpx;
  color: #8b96a5;
  font-size: 21rpx;
  line-height: 1.45;
}

.state-action {
  min-width: 192rpx;
  height: 68rpx;
  margin: 24rpx auto 0;
  padding: 0 24rpx;
  border-radius: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: #2f86f6;
  font-size: 23rpx;
  font-weight: 600;
}

.state-action.secondary {
  color: #2f86f6;
  background: #edf5ff;
}

.empty-record-icon {
  width: 74rpx;
  height: 74rpx;
  margin: 0 auto 16rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #2f86f6;
  background: #edf5ff;
  font-size: 38rpx;
  font-weight: 300;
}

.loading-card {
  min-height: 230rpx;
}

.skeleton {
  overflow: hidden;
  border-radius: 12rpx;
  background: #edf2f8;
}

.skeleton-title {
  width: 34%;
  height: 28rpx;
}

.skeleton-grid {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.skeleton-block {
  height: 64rpx;
}

.month-group-list {
  display: flex;
  flex-direction: column;
}

.month-group {
  padding: 20rpx;
}

.month-group-head {
  width: 100%;
  min-height: 136rpx;
  padding: 0 10rpx;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  overflow: hidden;
}

.month-group-head-row {
  width: 100%;
  min-width: 0;
  height: 68rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.month-group-action-slot {
  flex: 0 0 220rpx;
  width: 220rpx;
  min-width: 220rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  overflow: hidden;
}

.month-add-button-placeholder {
  width: 200rpx;
  height: 68rpx;
}

.month-group-toggle-button {
  flex: 0 0 200rpx;
  width: 200rpx;
  min-width: 0;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
  overflow: hidden;
  color: #607087;
  font-size: 26rpx;
  font-weight: 520;
  line-height: 1.2;
  text-align: right;
  white-space: nowrap;
}

.month-group-title {
  flex: 1;
  min-width: 0;
  height: auto;
  display: flex;
  align-items: center;
  overflow: hidden;
  color: #182231;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.2;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.month-group-summary {
  flex: 1;
  min-width: 0;
  height: auto;
  display: flex;
  align-items: center;
  overflow: hidden;
  color: #8994a3;
  font-size: 24rpx;
  font-weight: 450;
  line-height: 1.2;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.overview-month-group .month-group-title,
.overview-month-group .month-group-summary {
  justify-content: flex-start;
  text-align: left;
}

.month-group-toggle-label {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.month-group-toggle-icon {
  flex: 0 0 24rpx;
  width: 24rpx;
  height: 24rpx;
  display: block;
  transform: rotate(90deg);
  transform-origin: center;
  transition: transform 0.18s ease;
}

.month-group-toggle-icon.is-expanded {
  transform: rotate(-90deg);
}

.month-add-button {
  width: 200rpx;
  height: 68rpx;
  padding: 0 12rpx;
  border-radius: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #2f86f6;
  background: #edf5ff;
  font-size: 28rpx;
  font-weight: 600;
  white-space: nowrap;
}

.service-list {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.service-card {
  width: 100%;
  height: 184rpx;
  padding: 14rpx 16rpx;
  border-radius: 28rpx;
  display: grid;
  grid-template-columns: 88rpx minmax(0, 1fr) 148rpx 24rpx;
  align-items: center;
  column-gap: 12rpx;
  background: #fbfcfe;
  border: 1rpx solid #edf1f5;
  box-shadow: none;
}

.service-icon-shell {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #eaf4ff;
}

.service-icon {
  width: 72rpx;
  height: 72rpx;
}

.service-copy {
  min-width: 0;
}

.service-title {
  display: block;
  color: #182231;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.25;
  white-space: nowrap;
}

.service-meta-row {
  min-width: 0;
  margin-top: 6rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.service-meta-icon {
  flex: 0 0 auto;
  width: 20rpx;
  height: 20rpx;
}

.service-meta-text {
  min-width: 0;
  overflow: hidden;
  color: #7b8796;
  font-size: 24rpx;
  font-weight: 430;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.location-meta-text {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.service-side {
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: center;
  gap: 10rpx;
}

.service-price {
  color: #182231;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.1;
  white-space: nowrap;
}

.service-status {
  min-width: 84rpx;
  height: 46rpx;
  padding: 0 10rpx;
  border-radius: 23rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #27a95b;
  background: #edf9f1;
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1;
  white-space: nowrap;
}

.service-chevron {
  width: 22rpx;
  height: 22rpx;
  align-self: center;
  justify-self: end;
}

.trend-card {
  padding: 28rpx 28rpx 20rpx;
}

.section-row {
  width: 100%;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  box-sizing: border-box;
}

.section-copy {
  flex: 1;
  min-width: 0;
}

.section-title {
  display: block;
  color: #182231;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.2;
}

.section-subtitle {
  display: block;
  margin-top: 7rpx;
  color: #8994a3;
  font-size: 24rpx;
  font-weight: 430;
  line-height: 1.25;
}

.trend-wrap {
  margin-top: 20rpx;
  display: flex;
  gap: 6rpx;
}

.trend-axis {
  position: relative;
  flex: 0 0 46rpx;
  width: 46rpx;
  height: 330rpx;
}

.trend-axis-label {
  position: absolute;
  left: 0;
  color: #a6afbb;
  font-size: 20rpx;
  font-weight: 400;
  line-height: 1;
  transform: translateY(-50%);
}

.axis-0 { top: 16rpx; }
.axis-1 { top: 106rpx; }
.axis-2 { top: 196rpx; }
.axis-3 { top: 286rpx; }

.trend-plot {
  position: relative;
  flex: 1;
  min-width: 0;
  height: 330rpx;
}

.trend-grid-line {
  position: absolute;
  left: 0;
  right: 0;
  border-top: 1rpx dashed #e8edf3;
}

.line-top { top: 16rpx; }
.line-mid { top: 106rpx; }
.line-low { top: 196rpx; }
.line-base { top: 286rpx; }

.trend-grid-line.solid {
  border-top-style: solid;
}

.trend-bars {
  position: absolute;
  left: 14rpx;
  right: 20rpx;
  top: 0;
  bottom: 0;
  display: grid;
  grid-template-columns: repeat(6, minmax(0, 1fr));
}

.trend-bar-col {
  width: 100%;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
}

.trend-bar-value {
  min-height: 30rpx;
  margin-bottom: 6rpx;
  color: #6f7b8b;
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1.2;
}

.trend-bar-value.current {
  color: #2f86f6;
}

.trend-bar-shell {
  width: 24rpx;
  height: 240rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.trend-bar-fill {
  width: 24rpx;
  min-height: 8rpx;
  border-radius: 10rpx 10rpx 0 0;
  background: #c6ddfa;
}

.trend-bar-fill.zero {
  min-height: 5rpx;
  background: #e7edf5;
}

.trend-bar-fill.current {
  background: #2f86f6;
}

.trend-bar-label {
  width: 100%;
  min-width: 0;
  margin-top: 11rpx;
  color: #7c8796;
  font-size: 22rpx;
  font-weight: 430;
  line-height: 1.2;
  text-align: center;
  white-space: nowrap;
}

.trend-bar-label.current {
  color: #2f86f6;
  font-weight: 600;
}

.trend-card-full .trend-axis,
.trend-card-full .trend-plot {
  height: 390rpx;
}

.trend-card-full .axis-0,
.trend-card-full .line-top { top: 18rpx; }

.trend-card-full .axis-1,
.trend-card-full .line-mid { top: 126rpx; }

.trend-card-full .axis-2,
.trend-card-full .line-low { top: 234rpx; }

.trend-card-full .axis-3,
.trend-card-full .line-base { top: 342rpx; }

.trend-card-full .trend-bar-shell {
  height: 300rpx;
}

.trend-empty {
  min-height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.trend-empty-bars {
  height: 84rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 18rpx;
}

.trend-empty-bar {
  width: 16rpx;
  height: 8rpx;
  border-radius: 8rpx 8rpx 0 0;
  background: #e5ebf3;
}

.trend-empty-title {
  display: block;
  color: #667386;
  font-size: 24rpx;
  font-weight: 600;
}

.trend-empty-description {
  display: block;
  margin-top: 8rpx;
  color: #9aa4b2;
  font-size: 19rpx;
}

.record-page .bottom-nav {
  z-index: 30;
  background: #ffffff;
  border-top-color: #e3e9f0;
  box-shadow: 0 -6rpx 18rpx rgba(35, 76, 126, 0.055);
}

.record-page .bottom-nav-item.active {
  color: #2f86f6;
}

.record-sheet-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 60;
  display: flex;
  align-items: flex-end;
  padding-right: 24rpx;
  padding-bottom: calc(28rpx + env(safe-area-inset-bottom));
  padding-left: 24rpx;
  box-sizing: border-box;
  background: rgba(12, 25, 44, 0.42);
}

.record-sheet {
  width: 100%;
  height: 100%;
  max-height: 100%;
  border-radius: 40rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: #ffffff;
}

.sheet-head {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 28rpx 28rpx 22rpx;
  border-bottom: 1rpx solid #edf1f5;
}

.sheet-head-copy {
  flex: 1;
  min-width: 0;
}

.sheet-title {
  display: block;
  color: #172033;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.2;
  text-align: left;
}

.sheet-subtitle {
  display: block;
  margin-top: 8rpx;
  color: #8b95a6;
  font-size: 23rpx;
  line-height: 1.35;
  text-align: left;
}

.sheet-close {
  flex: 0 0 60rpx;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #687386;
  background: #eef3f9;
  font-size: 32rpx;
  font-weight: 300;
}

.sheet-body {
  flex: 0 0 auto;
  height: calc(100% - 266rpx);
  min-height: 0;
  width: 100%;
}

.sheet-form {
  padding: 24rpx 28rpx 32rpx;
  box-sizing: border-box;
}

.form-grid {
  width: 100%;
  display: flex;
  box-sizing: border-box;
}

.form-grid-section {
  flex: 0 0 calc((100% - 22rpx) / 2);
  width: calc((100% - 22rpx) / 2);
  min-width: 0;
}

.form-grid-section-left {
  margin-right: 22rpx;
}

.form-section {
  width: 100%;
  margin-bottom: 32rpx;
  box-sizing: border-box;
}

.form-label {
  display: block;
  margin-bottom: 12rpx;
  color: #465266;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.2;
}

.form-input,
.form-picker-value,
.cost-input-wrap {
  width: 100%;
  height: 84rpx;
  padding: 0 20rpx;
  border-radius: 22rpx;
  box-sizing: border-box;
  color: #172033;
  background: #f5f8fc;
  font-size: 26rpx;
  font-weight: 500;
  line-height: 84rpx;
}

.form-input {
  display: block;
}

.form-picker-value,
.cost-input-wrap {
  display: flex;
  align-items: center;
}

.form-placeholder {
  color: #95a0af;
  font-weight: 400;
}

.cost-input-wrap {
  padding: 0 0 0 20rpx;
}

.cost-prefix {
  flex: 0 0 auto;
  margin-right: 10rpx;
  color: #172033;
  font-size: 29rpx;
  font-weight: 700;
}

.cost-input {
  flex: 1;
  width: auto;
  min-width: 0;
  padding: 0 20rpx 0 0;
  background: transparent;
}

.form-location-input {
  height: 104rpx;
  line-height: 104rpx;
}

.option-grid {
  width: 100%;
  display: flex;
  flex-wrap: wrap;
  align-items: stretch;
  box-sizing: border-box;
}

.option-item {
  flex: 0 0 calc((100% - 20rpx) / 2);
  width: calc((100% - 20rpx) / 2);
  min-width: 0;
  height: 68rpx;
  margin-bottom: 20rpx;
  padding: 0 16rpx;
  border-radius: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  color: #667386;
  background: #f1f5fa;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1;
}

.option-item-0,
.option-item-2 {
  margin-right: 20rpx;
}

.option-item-2,
.option-item-3 {
  margin-bottom: 0;
}

.option-item.active {
  color: #ffffff;
  background: #2f86f6;
}

.form-textarea {
  width: 100%;
  height: 188rpx;
  min-height: 188rpx;
  max-height: 188rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  display: block;
  box-sizing: border-box;
  color: #172033;
  background: #f5f8fc;
  font-size: 26rpx;
  line-height: 1.45;
}

.form-note-section {
  margin-bottom: 0;
}

.sheet-actions {
  flex: 0 0 auto;
  padding: 18rpx 28rpx 24rpx;
  box-sizing: border-box;
  background: #ffffff;
  border-top: 1rpx solid #edf1f5;
}

.sheet-primary {
  width: 100%;
  height: 92rpx;
  border-radius: 46rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: #2f86f6;
  font-size: 28rpx;
  font-weight: 700;
}
