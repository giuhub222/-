.record-page {
  min-height: 100vh;
  padding: 26rpx 24rpx 206rpx;
  background: linear-gradient(180deg, #f7fbff 0%, #f3f8ff 46%, #ffffff 100%);
}

.record-filter-row {
  height: 66rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  margin: 0 0 26rpx;
}

.record-filter {
  width: 134rpx;
  min-width: 134rpx;
  height: 54rpx;
  margin: 0 auto 0 0;
  padding: 0 24rpx;
  border-radius: 27rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  background: rgba(238, 243, 250, 0.88);
  color: #687386;
  font-size: 24rpx;
  font-weight: 400;
}

.record-filter.active {
  background: #2f86f6;
  color: #ffffff;
  box-shadow: 0 12rpx 24rpx rgba(47, 134, 246, 0.22);
}

.filter-arrow {
  font-size: 18rpx;
  transform: translateY(1rpx);
}

.timeline-heading {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin: 0 4rpx 18rpx;
}

.timeline-title {
  display: block;
  color: #1f2937;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.2;
}

.timeline-count,
.timeline-month-label {
  display: block;
  margin-top: 8rpx;
  color: #8993a4;
  font-size: 22rpx;
  font-weight: 400;
  line-height: 1.2;
}

.timeline-month-label {
  margin-top: 0;
  text-align: right;
}

.empty-state {
  padding: 36rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.empty-title {
  color: #172033;
  font-size: 30rpx;
  font-weight: 500;
}

.empty-text {
  color: #7b8492;
  font-size: 24rpx;
  font-weight: 400;
  line-height: 1.5;
}

.timeline-wrap {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.month-title {
  display: block;
  margin: 0 0 14rpx 14rpx;
  color: #1f2937;
  font-size: 27rpx;
  font-weight: 600;
  line-height: 1.2;
}

.timeline-list {
  display: flex;
  flex-direction: column;
}

.timeline-item {
  display: grid;
  grid-template-columns: 106rpx 28rpx minmax(0, 1fr);
  column-gap: 12rpx;
  min-height: 156rpx;
  position: relative;
}

.time-col {
  padding-top: 22rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  min-width: 0;
}

.time-date {
  color: #172033;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.2;
}

.time-week,
.time-clock {
  margin-top: 8rpx;
  color: #8b95a6;
  font-size: 20rpx;
  font-weight: 400;
  line-height: 1.15;
  max-width: 96rpx;
  text-align: right;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.line-col {
  position: relative;
  display: flex;
  justify-content: center;
}

.timeline-line {
  position: absolute;
  top: 36rpx;
  bottom: 0;
  width: 2rpx;
  background: #d7e5f5;
}

.timeline-dot {
  position: relative;
  z-index: 1;
  width: 14rpx;
  height: 14rpx;
  margin-top: 26rpx;
  border-radius: 50%;
  background: #2f86f6;
  border: 4rpx solid #e8f2ff;
}

.timeline-dot.green {
  background: #30c267;
  border-color: #e8f8ef;
}

.record-card {
  min-width: 0;
  margin-bottom: 18rpx;
  padding: 22rpx 22rpx 22rpx 20rpx;
  display: grid;
  grid-template-columns: 68rpx minmax(0, 1fr) auto;
  align-items: center;
  column-gap: 18rpx;
}

.record-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1f78f0 0%, #4b9cff 100%);
}

.record-icon.green {
  background: linear-gradient(135deg, #22b95c 0%, #45d17a 100%);
}

.record-icon image {
  width: 36rpx;
  height: 36rpx;
}

.record-info {
  min-width: 0;
}

.record-title-row {
  display: flex;
  align-items: center;
  min-width: 0;
  gap: 10rpx;
}

.record-title {
  color: #172033;
  font-size: 29rpx;
  font-weight: 600;
  line-height: 1.2;
  white-space: nowrap;
}

.record-badge {
  max-width: 128rpx;
  height: 30rpx;
  padding: 0 10rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #2f86f6;
  background: rgba(47, 134, 246, 0.1);
  font-size: 19rpx;
  font-weight: 500;
  line-height: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.record-badge.green {
  color: #22a95a;
  background: rgba(48, 194, 103, 0.12);
}

.record-detail,
.record-meta {
  display: block;
  min-width: 0;
  margin-top: 8rpx;
  color: #657084;
  font-size: 22rpx;
  font-weight: 400;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-meta {
  color: #99a2b1;
  font-size: 21rpx;
}

.record-status {
  align-self: end;
  color: #172033;
  font-size: 23rpx;
  font-weight: 600;
  line-height: 1.2;
  white-space: nowrap;
}

.floating-add {
  position: fixed;
  right: 32rpx;
  bottom: calc(144rpx + env(safe-area-inset-bottom));
  z-index: 25;
  height: 70rpx;
  min-width: 176rpx;
  padding: 0 28rpx;
  border-radius: 35rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #1f78f0 0%, #2f86f6 100%);
  box-shadow: 0 16rpx 32rpx rgba(47, 134, 246, 0.3);
  font-size: 26rpx;
  font-weight: 500;
}

.floating-plus {
  font-size: 38rpx;
  font-weight: 300;
  line-height: 1;
  transform: translateY(-1rpx);
}
