.hero {
  padding: 34rpx 30rpx 32rpx;
}

.eyebrow {
  display: block;
  color: #007aff;
  font-size: 23rpx;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.title {
  display: block;
  color: #111827;
  font-size: 32rpx;
  font-weight: 600;
}

.big {
  display: block;
  margin: 26rpx 0 30rpx;
  color: #111827;
  font-size: 68rpx;
  line-height: 1;
  font-weight: 500;
  letter-spacing: 0;
}

.primary-button {
  min-width: 0;
  height: 84rpx;
  border-radius: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #007aff;
  color: #fff;
  font-size: 27rpx;
  font-weight: 600;
  white-space: nowrap;
  box-shadow: 0 18rpx 34rpx rgba(0, 122, 255, 0.22);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 34rpx 6rpx 18rpx;
  color: #8a93a1;
  font-size: 23rpx;
  font-weight: 500;
}

.section-head button {
  min-width: 96rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  background: rgba(255, 59, 48, 0.08);
  color: #ff3b30;
  font-size: 24rpx;
  font-weight: 600;
}

.empty {
  padding: 32rpx 30rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  color: #111827;
  font-size: 29rpx;
  font-weight: 500;
}

.empty .muted {
  font-size: 25rpx;
  font-weight: 400;
  line-height: 1.5;
}

.record-list {
  display: flex;
  flex-direction: column;
}

.record-row {
  min-height: 102rpx;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.record-row + .record-row {
  margin-top: 12rpx;
}

.record-date {
  display: block;
  color: #111827;
  font-size: 29rpx;
  font-weight: 500;
}

.record-source {
  display: block;
  margin-top: 8rpx;
  color: #8a93a1;
  font-size: 23rpx;
}

.record-ago {
  color: #007aff;
  font-size: 26rpx;
  font-weight: 500;
}
