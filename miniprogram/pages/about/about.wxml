<view class="page-shell about-page">
  <view class="profile-gradient">
    <view class="profile-card glass-card">
      <view class="profile-main">
        <view class="avatar-shell">
          <image src="{{avatarUrl}}" mode="aspectFill" />
          <button class="avatar-button" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar" hover-class="none"></button>
        </view>
        <view class="profile-copy">
          <text wx:if="{{isLoggedIn}}" class="profile-name">{{displayName}}</text>
          <input
            wx:else
            class="nickname-input"
            type="nickname"
            placeholder="填写微信昵称"
            placeholder-class="nickname-placeholder"
            value="{{draftNickname}}"
            bindinput="onNicknameInput"
          />
          <text class="profile-desc">洗车让我爱车更闪亮</text>
          <text class="login-meta">{{profileDesc}}</text>
        </view>
      </view>

      <button wx:if="{{!isLoggedIn}}" class="login-button" bindtap="loginWithWechat" hover-class="none">
        微信授权登录
      </button>
      <view wx:else class="logged-row">
        <text class="logged-badge">已登录</text>
        <button class="logout-button" bindtap="logout" hover-class="none">退出</button>
      </view>

      <text class="data-title">我的数据</text>
      <view class="stats-grid">
        <view wx:for="{{stats}}" wx:key="label" class="stat-item">
          <text class="stat-value">{{item.value}}</text>
          <text class="stat-label">{{item.label}}</text>
        </view>
      </view>

      <button class="settings-row" bindtap="showSettings" hover-class="none">
        <view class="settings-left">
          <view class="settings-icon">
            <image src="/assets/icons/ui/settings-blue.svg" mode="aspectFit" />
          </view>
          <text class="settings-label">设置</text>
        </view>
        <image class="chevron-icon" src="/assets/icons/ui/chevron-right-gray.svg" mode="aspectFit" />
      </button>
    </view>
  </view>

  <view class="about-note glass-card">
    <view class="note-row">
      <text class="note-label">登录状态</text>
      <text class="note-value">{{loginMeta}}</text>
    </view>
    <view class="note-row">
      <text class="note-label">身份方式</text>
      <text class="note-value">{{identityText}}</text>
    </view>
    <view class="note-row">
      <text class="note-label">最近洗车</text>
      <text class="note-value">{{lastWashText}}</text>
    </view>
    <view class="note-row">
      <text class="note-label">数据说明</text>
      <text class="note-value">记录保存在本机</text>
    </view>
    <button class="config-button" bindtap="copyEnvName" hover-class="none">复制天气变量名</button>
  </view>

  <view class="bottom-nav">
    <button class="bottom-nav-item nav-slot-1" bindtap="goIndex" hover-class="none">
      <view class="bottom-nav-inner">
        <image class="bottom-nav-icon" src="/assets/icons/ui/nav-car-muted.svg" mode="aspectFit" />
        <text class="bottom-nav-label">洗车指数</text>
      </view>
    </button>
    <button class="bottom-nav-item nav-slot-2" bindtap="goRecord" hover-class="none">
      <view class="bottom-nav-inner">
        <image class="bottom-nav-icon" src="/assets/icons/ui/nav-record-muted.svg" mode="aspectFit" />
        <text class="bottom-nav-label">洗车记录</text>
      </view>
    </button>
    <button class="bottom-nav-item nav-slot-3 active" hover-class="none">
      <view class="bottom-nav-inner">
        <image class="bottom-nav-icon" src="/assets/icons/ui/nav-user-active.svg" mode="aspectFit" />
        <text class="bottom-nav-label">我的</text>
      </view>
    </button>
  </view>
</view>
