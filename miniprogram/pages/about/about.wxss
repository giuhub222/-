.header {
  margin-bottom: 28rpx;
  padding: 2rpx 2rpx 0;
}

.eyebrow {
  display: block;
  color: #007aff;
  font-size: 23rpx;
  font-weight: 500;
  margin-bottom: 10rpx;
}

.title {
  display: block;
  color: #111827;
  font-size: 42rpx;
  line-height: 1.08;
  font-weight: 600;
  letter-spacing: 0;
}

.subtitle {
  display: block;
  margin-top: 12rpx;
  color: #7d8795;
  font-size: 25rpx;
  line-height: 1.45;
}

.card {
  margin-bottom: 16rpx;
  padding: 28rpx;
}

.card-title {
  display: block;
  margin-bottom: 18rpx;
  color: #111827;
  font-size: 29rpx;
  font-weight: 600;
}

.check-row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-top: 14rpx;
  color: #475569;
  font-size: 25rpx;
  line-height: 1.45;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  margin-top: 14rpx;
  border-radius: 50%;
  background: #34c759;
  flex: 0 0 auto;
}

.paragraph {
  display: block;
  color: #475569;
  font-size: 25rpx;
  line-height: 1.55;
}

.copy-button {
  width: 220rpx;
  height: 72rpx;
  margin-top: 22rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #007aff;
  color: #fff;
  font-size: 25rpx;
  font-weight: 600;
  box-shadow: 0 14rpx 30rpx rgba(0, 122, 255, 0.18);
}
