.about-page {
  min-height: 100vh;
  padding: 0 24rpx 206rpx;
  background: linear-gradient(180deg, #eaf5ff 0%, #f7fbff 42%, #ffffff 100%);
}

.profile-gradient {
  margin: 0 -24rpx;
  min-height: 520rpx;
  padding: 42rpx 24rpx 48rpx;
  background:
    radial-gradient(circle at 18% 78%, rgba(255, 255, 255, 0.46) 0, rgba(255, 255, 255, 0.46) 34rpx, transparent 35rpx),
    radial-gradient(circle at 78% 18%, rgba(255, 255, 255, 0.2) 0, rgba(255, 255, 255, 0.2) 52rpx, transparent 53rpx),
    linear-gradient(135deg, #2792ff 0%, #75d8ff 100%);
}

.profile-card {
  padding: 34rpx 28rpx 24rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 22rpx 52rpx rgba(35, 103, 171, 0.14);
}

.profile-main {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.avatar-shell {
  position: relative;
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  background: linear-gradient(135deg, #edf7ff 0%, #d8efff 100%);
  border: 6rpx solid rgba(255, 255, 255, 0.96);
  box-shadow: 0 14rpx 30rpx rgba(47, 134, 246, 0.16);
  overflow: hidden;
}

.avatar-button {
  position: absolute;
  inset: 0;
  z-index: 3;
  width: 100%;
  height: 100%;
  min-width: 0;
  padding: 0;
  margin: 0;
  border-radius: 50%;
  opacity: 0;
}

.avatar-shell image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: block;
}

.profile-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.profile-name {
  color: #172033;
  font-size: 34rpx;
  font-weight: 600;
  line-height: 1.2;
}

.nickname-input {
  width: 330rpx;
  height: 46rpx;
  padding: 0;
  color: #172033;
  font-size: 34rpx;
  font-weight: 600;
  line-height: 46rpx;
}

.nickname-placeholder {
  color: #a5afbd;
  font-weight: 500;
}

.profile-desc {
  color: #7d8795;
  font-size: 23rpx;
  font-weight: 400;
  line-height: 1.35;
}

.login-meta {
  color: #9aa4b4;
  font-size: 21rpx;
  font-weight: 400;
  line-height: 1.25;
}

.login-button {
  width: 100%;
  height: 78rpx;
  margin-top: 30rpx;
  border-radius: 39rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: linear-gradient(135deg, #1f78f0 0%, #2f86f6 100%);
  box-shadow: 0 16rpx 32rpx rgba(47, 134, 246, 0.24);
  font-size: 27rpx;
  font-weight: 500;
}

.logged-row {
  height: 58rpx;
  margin-top: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.logged-badge {
  height: 42rpx;
  padding: 0 18rpx;
  border-radius: 21rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #2f86f6;
  background: rgba(47, 134, 246, 0.1);
  font-size: 22rpx;
  font-weight: 500;
}

.logout-button {
  min-width: 96rpx;
  height: 48rpx;
  padding: 0 20rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #7d8795;
  background: rgba(239, 244, 250, 0.92);
  font-size: 23rpx;
  font-weight: 400;
}

.data-title {
  display: block;
  margin-top: 36rpx;
  color: #172033;
  font-size: 23rpx;
  font-weight: 600;
  line-height: 1.2;
}

.stats-grid {
  margin-top: 28rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  column-gap: 8rpx;
}

.stat-item {
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.stat-value {
  color: #172033;
  font-size: 38rpx;
  font-weight: 500;
  line-height: 1;
}

.stat-label {
  color: #7d8795;
  font-size: 21rpx;
  font-weight: 400;
  line-height: 1.2;
  white-space: nowrap;
}

.settings-row {
  width: 100%;
  height: 84rpx;
  margin-top: 34rpx;
  padding: 0 4rpx;
  border-top: 1rpx solid rgba(216, 227, 240, 0.8);
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  color: #172033;
}

.settings-left {
  height: 58rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.settings-icon {
  width: 34rpx;
  height: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.settings-icon image {
  width: 32rpx;
  height: 32rpx;
}

.settings-label {
  font-size: 25rpx;
  font-weight: 500;
  line-height: 1;
}

.chevron-icon {
  width: 28rpx;
  height: 28rpx;
  margin-bottom: 15rpx;
}

.about-note {
  margin-top: -24rpx;
  padding: 28rpx;
  border-radius: 24rpx;
}

.note-row {
  min-height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.note-row + .note-row {
  border-top: 1rpx solid rgba(216, 227, 240, 0.72);
  padding-top: 18rpx;
  margin-top: 18rpx;
}

.note-label {
  color: #7d8795;
  font-size: 24rpx;
  font-weight: 400;
  line-height: 1.2;
  white-space: nowrap;
}

.note-value {
  min-width: 0;
  color: #172033;
  font-size: 25rpx;
  font-weight: 500;
  line-height: 1.25;
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.config-button {
  height: 68rpx;
  margin-top: 24rpx;
  border-radius: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #2f86f6;
  background: rgba(47, 134, 246, 0.08);
  font-size: 24rpx;
  font-weight: 500;
}
